# --- New Relic ---
NR_API_KEY=NRAK-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
NR_ACCOUNT_ID=0000000
NR_REGION=US
NR_INGEST_LICENSE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxNRAL

# --- Postgres / TimescaleDB ---
PG_HOST=localhost
PG_PORT=5432
PG_DB=survpredict
PG_USER=survpredict
PG_PASSWORD=survpredict

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=s3://survpredict-artifacts

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-7

# --- Service ---
SURVPREDICT_ENV=dev
SURVPREDICT_LOG_LEVEL=INFO
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=8080

# --- Propagation / thresholds ---
PROPAGATION_HAZARD_THRESHOLD=0.6
PROPAGATION_MAX_HOPS=3
WARM_SWEEP_SECONDS=60
